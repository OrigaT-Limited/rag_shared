# --- DashScope API ---
DASHSCOPE_API_KEY=yourkey

# --- VLM (Vision Language Model) ---
VLM_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
VLM_MODEL=qwen-vl-max

# --- Embedding ---
EMBED_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBED_MODEL=text-embedding-v4
EMBED_DIM=1024

# --- Milvus Standalone ---
# LightRAG reads these env vars directly for MilvusVectorDBStorage.
# Creates 3 collections per workspace: {workspace}_entities, {workspace}_relationships, {workspace}_chunks
MILVUS_URI=http://localhost:19530
# MILVUS_USER=
# MILVUS_PASSWORD=
# MILVUS_TOKEN=
MILVUS_DB_NAME=default
# MILVUS_WORKSPACE=    # Override workspace prefix for collection names

# --- Redis (KV + doc-status storage) ---
# LightRAG reads REDIS_URI directly for RedisKVStorage / RedisDocStatusStorage.
# Stores: full_docs, text_chunks, llm_response_cache, full_entities, full_relations, doc_status
REDIS_URI=redis://localhost:6379
# REDIS_MAX_CONNECTIONS=200
# REDIS_SOCKET_TIMEOUT=30.0
# REDIS_CONNECT_TIMEOUT=10.0
# REDIS_WORKSPACE=     # Override workspace prefix for Redis keys

# --- Graph Storage ---
# LightRAG graph backend selector: "NetworkXStorage" (local, default) or "Neo4JStorage".
# NetworkXStorage persists to a local .graphml file — no external service needed.
# Neo4JStorage requires a running Neo4j instance and the env vars below.
GRAPH_STORAGE=NetworkXStorage

# --- Neo4j (graph storage, required when GRAPH_STORAGE=Neo4JStorage) ---
# LightRAG reads these env vars directly for Neo4JStorage.
# NEO4J_URI=neo4j://localhost:7687
# NEO4J_USERNAME=neo4j      # Optional for the official Docker image; defaults to neo4j
# NEO4J_PASSWORD=your-neo4j-password
# NEO4J_DATABASE=neo4j
# NEO4J_WORKSPACE=     # Override workspace label for node isolation

# --- Timeouts ---
RAG_TIMEOUT=120
